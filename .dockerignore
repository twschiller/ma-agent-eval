# Build-context excludes: keep the image build fast and the context small.
# Everything here is regenerated inside the image, dev-only, or a secret.
# The build needs source (config/, maeval/, manage.py), pyproject.toml, and
# uv.lock — nothing below.

# Virtualenv — recreated by `uv sync` in the builder. Never ship the host's
# (it's built for macOS/arm and would just be overwritten anyway).
.venv/

# VCS and CI config
.git/
.gitignore
.github/

# Agent / editor / design-skill tooling — not needed to build or run
.claude/
.impeccable/
.vscode/
.idea/

# Docs and project prose — not imported at runtime
docs/

# Tool caches
.ruff_cache/
.mypy_cache/
.pytest_cache/
.hypothesis/

# Python bytecode
__pycache__/
*.py[cod]

# Collected static assets — regenerated by collectstatic at build time
staticfiles/
static/

# Local env files / secrets — the image gets config via `fly secrets` at runtime
.env
.env.*

# Local data / scratch and logs
data/
*.log
